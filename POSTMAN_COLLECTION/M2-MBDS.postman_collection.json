						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Product\",\n  \"rowCount\": 30,\n  \"fields\": [\n    {\n      \"name\": \"productId\",\n      \"type\": \"AUTOINCREMENT\",\n      \"constraints\": {\n        \"start\": 1000,\n        \"step\": 5\n      }\n    },\n    {\n      \"name\": \"owner\",\n      \"type\": \"NAME\",\n      \"constraints\": {\n        \"language\": \"en\",\n        \"style\": \"lastname_firstname\"\n      }\n    },\n    {\n      \"name\": \"price\",\n      \"type\": \"INTEGER\",\n      \"constraints\": {\n        \"min\": 5,\n        \"max\": 999\n      }\n    },\n    {\n      \"name\": \"category\",\n      \"type\": \"ENUM\",\n      \"constraints\": {\n        \"values\": [\"ELECTRONICS\", \"CLOTHING\", \"FOOD\", \"SPORTS\"],\n        \"probabilities\": [0.3, 0.25, 0.25, 0.2]\n      }\n    },\n    {\n      \"name\": \"sku\",\n      \"type\": \"STRING\",\n      \"constraints\": {\n        \"length\": 12\n      }\n    },\n    {\n      \"name\": \"releaseDate\",\n      \"type\": \"DATE\",\n      \"constraints\": {\n        \"from\": \"2020-01-01\",\n        \"to\": \"2024-12-31\"\n      }\n    },\n    {\n      \"name\": \"contactEmail\",\n      \"type\": \"EMAIL\",\n      \"constraints\": {\n        \"domain\": \"shop.com\"\n      }\n    }\n  ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
