				{
					"name": "A5 - POST create entity in project",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200 or 201', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
									"});",
									"pm.test('Entity has id', function () {",
									"    var body = pm.response.json();",
									"    pm.expect(body).to.have.property('id');",
									"});",
									"pm.test('Entity name is correct', function () {",
									"    var body = pm.response.json();",
									"    pm.expect(body.name).to.eql('User');",
									"});",
									"pm.test('Entity has fields array', function () {",
									"    var body = pm.response.json();",
									"    pm.expect(body.fields).to.be.an('array');",
									"    pm.expect(body.fields).to.have.lengthOf.above(0);",
									"});",
									"pm.environment.set('unit_entity_id', pm.response.json().id);"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
