								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"User\",\n  \"fields\": [\n    { \"name\": \"id\",    \"type\": \"AUTOINCREMENT\", \"constraints\": { \"start\": 1, \"step\": 1 } },\n    { \"name\": \"name\",  \"type\": \"NAME\",           \"constraints\": { \"language\": \"fr\" } },\n    { \"name\": \"age\",   \"type\": \"INTEGER\",        \"constraints\": { \"min\": 18, \"max\": 65 } },\n    { \"name\": \"email\", \"type\": \"STRING\",         \"constraints\": { \"minLength\": 5, \"maxLength\": 30 } },\n    { \"name\": \"dob\",   \"type\": \"DATE\",           \"constraints\": { \"after\": \"1960-01-01\", \"before\": \"2005-12-31\" } },\n    { \"name\": \"role\",  \"type\": \"ENUM\",           \"constraints\": { \"values\": [\"ADMIN\", \"USER\", \"GUEST\"] } }\n  ]\n}"
						},
