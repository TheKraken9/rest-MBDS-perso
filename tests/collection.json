    {
      "name": "C. Integration Scenario",
      "description": "Full lifecycle scenario: create project → add entity with sub-entities → preview → export all formats → update entity → delete everything. Variable chaining with pm.environment.set().",
      "item": [
        {
          "name": "C01 - Create project",
